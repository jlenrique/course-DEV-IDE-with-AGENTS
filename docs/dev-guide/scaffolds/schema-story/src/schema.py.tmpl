class {{SCHEMA_NAME}}(BaseModel):
    """Top-level primitive for Story {{STORY_KEY}}.

    The field list below is placeholder-illustrative; replace with this story's
    actual contract shape. Retain the idioms:
        - ConfigDict with extra="forbid" + validate_assignment=True
        - tz-aware datetime validator
        - SCHEMA_VERSION field at the root level
    """

    model_config = ConfigDict(extra="forbid", validate_assignment=True)

    # Version field - keep at the top; AC-C.2 schema-version-field-present tests on it.
    schema_version: str = Field(
        default=SCHEMA_VERSION,
        description="Pinned to SCHEMA_VERSION; changes drive CHANGELOG entries.",
    )

    # Example primitive fields - replace for this story.
    identifier: str = Field(..., min_length=1, description="Stable primary key.")
    created_at: datetime = Field(
        default_factory=lambda: datetime.now(tz=UTC),
        description="Creation timestamp; timezone-aware UTC enforced.",
    )

    # Optional: UUID4 field if this story has one.
    # If you enable this block, add ``from uuid import UUID`` above.
    # event_id: str = Field(..., description="UUID4 string.")

    # Optional: rationale-style free-text verbatim field (no min_length).
    # rationale: str = Field(
    #     default="",
    #     description="Free text, stored verbatim, surfaced verbatim.",
    # )

    # Optional: internal audit-only fields.
    # If you enable this block, add:
    #   from typing import Literal
    #   from pydantic.json_schema import SkipJsonSchema
    # _internal_actor: SkipJsonSchema[
    #     Literal["marcus", "irene", "maya"]
    # ] = Field(
    #     default="marcus",
    #     exclude=True,
    #     description="Precise audit-surface actor; never serialized to Maya-facing payloads.",
    # )

    @field_validator("created_at")
    @classmethod
    def _enforce_tz_aware(cls, value: datetime) -> datetime:
        """Reject naive datetimes."""
        if value.tzinfo is None:
            raise ValueError("datetime field must be timezone-aware")
        return value

