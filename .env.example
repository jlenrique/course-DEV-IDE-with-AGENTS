# Copy to .env and fill in. Cursor / Claude Code load from environment or dotenv tools.
# See resources/tool-inventory/tool-access-matrix.md for full tool details.

# ============================================================
# TIER 1 — Full Programmatic Access (REST API + MCP Server)
# ============================================================

# --- Gamma (Slide Generation) ---
# API Docs: https://developers.gamma.app
# MCP: npx @raydeck/gamma-app-mcp
# Plan: Pro, Ultra, Teams, or Business required
GAMMA_API_KEY=

# --- ElevenLabs (Voice/Audio Synthesis) ---
# API Docs: https://elevenlabs.io/docs/api-reference
# Programmatic path in this repo: REST API now, Python client later.
# MCP: Available in theory, but not currently active in this repo because Cursor filters out surfaced tools due tool-name length limits.
# Plan: Free tier available (10k credits/month)
ELEVENLABS_API_KEY=

# --- Canvas LMS ---
# API Docs: https://canvas.instructure.com/doc/api/
# MCP: npx canvas-mcp-server (community, 54+ tools)
CANVAS_API_URL=https://your-institution.instructure.com
CANVAS_ACCESS_TOKEN=
CANVAS_DOMAIN=your-institution.instructure.com
CANVAS_SUBACCOUNT_ID=
CANVAS_DEFAULT_COURSE_ID=

# --- Qualtrics (Surveys/Assessments) ---
# API Docs: https://api.qualtrics.com/
# Programmatic path in this repo: REST API now, Python client later.
# MCP: Community server exists on GitHub, but is not currently active in this repo because it is not published on npm and needs a local build step.
QUALTRICS_API_TOKEN=
QUALTRICS_BASE_URL=https://yourdatacenter.qualtrics.com
QUALTRICS_DATA_CENTER_ID=
QUALTRICS_OWNER_ID=
QUALTRICS_ORGANIZATION_ID=
QUALTRICS_USERNAME=

# --- Canva (Design/Graphics) ---
# API Docs: https://canva.dev/docs/connect/
# MCP: Official remote MCP exists, but Cursor currently fails OAuth with an invalid redirect URL for this setup.
# Auth: Connect API uses OAuth; no static API key is used here.
# CANVA_CLIENT_ID=
# CANVA_CLIENT_SECRET=

# ============================================================
# TIER 2 — API Access Only (No Published MCP Server)
# ============================================================

# --- Botpress (Chatbot) ---
# API Docs: https://botpress.com/reference/botpress-api-documentation
BOTPRESS_API_KEY=
BOTPRESS_BOT_ID=

# --- Wondercraft (Audio Podcasting) ---
# API Docs: https://docs.wondercraft.ai/api-reference/introduction
# Plan: Paid plan required
WONDERCRAFT_API_KEY=

# --- Vyond (Video Animation) ---
# Note: API requires Enterprise plan. Manual workflow for non-Enterprise.
# VYOND_API_KEY=

# --- Kling (Video Generation) ---
# API Docs: https://klingapi.com/docs
# SDKs: kling-api (Python), @kling-api/sdk (Node.js)
# Auth: JWT — uses Access Key + Secret Key to generate Bearer tokens
# Get keys at: https://app.klingai.com/global/dev
KLING_ACCESS_KEY=
KLING_SECRET_KEY=

# --- Panopto (Video Platform) ---
# API Docs: https://your-instance.hosted.panopto.com/Panopto/api/docs/index.html
# GitHub Examples: https://github.com/Panopto/panopto-api-python-examples
PANOPTO_BASE_URL=https://your-instance.hosted.panopto.com
PANOPTO_CLIENT_ID=
PANOPTO_CLIENT_SECRET=

# ============================================================
# TIER 3 — Limited / Early Access API
# ============================================================

# --- Descript (Video/Audio Editing) ---
# API Docs: https://docs.descriptapi.com/ (Early Access)
# Note: Limited to import/export partner workflows, not full editing
DESCRIPT_API_KEY=

# --- Midjourney (Image Generation) ---
# Note: No official REST API. Third-party wrappers available.
# MIDJOURNEY_API_KEY=

# --- CapCut (Video Editing) ---
# Note: Official API status unclear. Third-party wrappers exist.
# CAPCUT_API_KEY=

# ============================================================
# TIER 4 — Manual Only (No API Keys Needed)
# ============================================================
# CourseArc — LTI 1.3 / SCORM integration only (no REST API)
# Articulate (Storyline/Rise) — Desktop/web authoring only (no API)

# ============================================================
# INFRASTRUCTURE
# ============================================================

# --- CourseArc (LTI/SCORM config, not API) ---
COURSEARC_BASE_URL=
# COURSEARC_LTI_KEY=
# COURSEARC_LTI_SECRET=

# --- Brave Search (for agent web research via MCP) ---
# Free tier: 2,000 queries/month. Get key at https://api.search.brave.com/app/keys
BRAVE_API_KEY=

# --- AI/LLM Providers (optional, for agent coordination) ---
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
