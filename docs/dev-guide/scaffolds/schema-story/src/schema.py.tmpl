class {{SCHEMA_NAME}}Ref(BaseModel):
    """Lightweight reference carried on emitted artifacts tied to this schema family."""

    model_config = ConfigDict(extra="forbid", frozen=True, validate_assignment=True)

    # Example field: replace with this story's reference primitives.
    key: str = Field(..., min_length=1, description="Stable identifier for the referent.")


