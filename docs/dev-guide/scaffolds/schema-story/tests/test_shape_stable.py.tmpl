{{SCHEMA_NAME_UPPER}}_REF_EXPECTED_FIELDS = frozenset({"key"})


def _model_field_names(model_cls) -> frozenset[str]:
    return frozenset(model_cls.model_fields.keys())


def _model_required_field_names(model_cls) -> frozenset[str]:
    return frozenset(
        name
        for name, field_info in model_cls.model_fields.items()
        if field_info.is_required()
    )


def test_{{schema_name}}_field_set_matches_allowlist() -> None:
    actual = _model_field_names({{SCHEMA_NAME}})
    assert actual == {{SCHEMA_NAME_UPPER}}_EXPECTED_FIELDS


def test_{{schema_name}}_required_fields_match() -> None:
    actual = _model_required_field_names({{SCHEMA_NAME}})
    assert actual == {{SCHEMA_NAME_UPPER}}_REQUIRED_FIELDS


def test_{{schema_name}}_ref_field_set_matches_allowlist() -> None:
    actual = _model_field_names({{SCHEMA_NAME}}Ref)
    assert actual == {{SCHEMA_NAME_UPPER}}_REF_EXPECTED_FIELDS


