{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SegmentManifest",
  "description": "Irene Pass 2 segment-manifest structural contract. Closes §7.1 failure modes from trial C1-M1-PRES-20260419B: §6.3 forbid legacy motion_asset key; §6.4 require visual_file on non-null-visual-mode segments; §6.5 require non-null motion_duration_seconds on motion (visual_mode=='video') segments. Value-vs-receipt cross-validation is NOT schema-enforced — see scripts/validators/pass_2_emission_lint.py for the upstream-reference check.",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "generated_at_utc",
    "generated_by",
    "segments"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.1"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "generated_at_utc": {
      "type": "string",
      "minLength": 1
    },
    "generated_by": {
      "type": "string",
      "minLength": 1
    },
    "segments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/segment"
      }
    },
    "reading_path": {
      "description": "Sprint 2 perception reading-path repertoire — envelope-level default pattern (Story perception-reading-path-repertoire). Optional in schema v1.1 for byte-identical backward compatibility with Sprint 1 7-1 fixtures; normalized from free-text 'narration_directive' at lint time when absent.",
      "$ref": "#/$defs/reading_path"
    },
    "narration_directive": {
      "description": "Free-text narration-directive hint (Sprint 1 convention). Sprint 2 adds the structured `reading_path` companion; the lint validator normalizes 'z-pattern-literal-scan' → reading_path.pattern='z_pattern' at validation time.",
      "type": ["string", "null"]
    }
  },
  "additionalProperties": true,
  "$defs": {
    "segment": {
      "type": "object",
      "required": [
        "id",
        "slide_id",
        "card_number",
        "visual_mode",
        "motion_asset_path",
        "motion_duration_seconds"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "slide_id": {
          "type": "string",
          "minLength": 1
        },
        "card_number": {
          "type": "integer",
          "minimum": 1
        },
        "visual_mode": {
          "type": ["string", "null"],
          "enum": ["video", "static", "animation", null]
        },
        "motion_asset_path": {
          "type": ["string", "null"],
          "minLength": 1
        },
        "motion_duration_seconds": {
          "type": ["number", "null"],
          "minimum": 0
        },
        "visual_file": {
          "type": "string",
          "minLength": 1
        },
        "retrieval_provenance": {
          "type": "array",
          "minItems": 1,
          "default": [],
          "items": {
            "$ref": "#/$defs/retrieval_provenance"
          }
        },
        "reading_path": {
          "description": "Per-segment reading-path override. Optional; when absent, the envelope-level reading_path applies.",
          "$ref": "#/$defs/reading_path"
        }
      },
      "additionalProperties": true,
      "allOf": [
        {
          "description": "§6.3 — legacy motion_asset key is forbidden; only motion_asset_path is emitted",
          "not": {
            "required": ["motion_asset"]
          }
        },
        {
          "description": "§6.4 — visual_file required on any segment with non-null visual_mode",
          "if": {
            "properties": {
              "visual_mode": {
                "type": "string"
              }
            },
            "required": ["visual_mode"]
          },
          "then": {
            "required": ["visual_file"],
            "properties": {
              "visual_file": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        {
          "description": "§6.5 — motion segments (visual_mode=='video') must carry non-null motion_duration_seconds and motion_asset_path",
          "if": {
            "properties": {
              "visual_mode": {
                "const": "video"
              }
            },
            "required": ["visual_mode"]
          },
          "then": {
            "required": ["motion_duration_seconds", "motion_asset_path"],
            "properties": {
              "motion_duration_seconds": {
                "type": "number",
                "exclusiveMinimum": 0
              },
              "motion_asset_path": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      ]
    },
    "provider_name": {
      "type": "string",
      "enum": ["scite", "consensus"]
    },
    "convergence_signal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "providers_agreeing",
        "providers_disagreeing",
        "single_source_only"
      ],
      "properties": {
        "providers_agreeing": {
          "type": "array",
          "uniqueItems": true,
          "maxItems": 2,
          "items": {
            "$ref": "#/$defs/provider_name"
          }
        },
        "providers_disagreeing": {
          "type": "array",
          "uniqueItems": true,
          "maxItems": 2,
          "items": {
            "$ref": "#/$defs/provider_name"
          }
        },
        "single_source_only": {
          "type": "array",
          "uniqueItems": true,
          "maxItems": 1,
          "items": {
            "$ref": "#/$defs/provider_name"
          }
        }
      },
      "allOf": [
        {
          "not": {
            "allOf": [
              {
                "properties": {
                  "providers_agreeing": {
                    "contains": {
                      "const": "scite"
                    }
                  }
                }
              },
              {
                "properties": {
                  "providers_disagreeing": {
                    "contains": {
                      "const": "scite"
                    }
                  }
                }
              }
            ]
          }
        },
        {
          "not": {
            "allOf": [
              {
                "properties": {
                  "providers_agreeing": {
                    "contains": {
                      "const": "consensus"
                    }
                  }
                }
              },
              {
                "properties": {
                  "providers_disagreeing": {
                    "contains": {
                      "const": "consensus"
                    }
                  }
                }
              }
            ]
          }
        },
        {
          "if": {
            "properties": {
              "providers_agreeing": {
                "allOf": [
                  {
                    "contains": {
                      "const": "scite"
                    }
                  },
                  {
                    "contains": {
                      "const": "consensus"
                    }
                  }
                ]
              }
            }
          },
          "then": {
            "properties": {
              "providers_disagreeing": {
                "maxItems": 0
              },
              "single_source_only": {
                "maxItems": 0
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "single_source_only": {
                "contains": {
                  "const": "scite"
                }
              }
            }
          },
          "then": {
            "properties": {
              "providers_agreeing": {
                "contains": {
                  "const": "scite"
                },
                "maxItems": 1
              },
              "providers_disagreeing": {
                "maxItems": 0
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "single_source_only": {
                "contains": {
                  "const": "consensus"
                }
              }
            }
          },
          "then": {
            "properties": {
              "providers_agreeing": {
                "contains": {
                  "const": "consensus"
                },
                "maxItems": 1
              },
              "providers_disagreeing": {
                "maxItems": 0
              }
            }
          }
        }
      ]
    },
    "retrieval_provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_id", "providers"],
      "properties": {
        "source_id": {
          "type": "string",
          "minLength": 1
        },
        "providers": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/provider_name"
          }
        },
        "convergence_signal": {
          "anyOf": [
            {
              "$ref": "#/$defs/convergence_signal"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "reading_path": {
      "description": "Sprint 2 reading-path repertoire sub-object. Closed enum of 7 patterns + classifier confidence + evidence details + fallback flag. Story perception-reading-path-repertoire. See state/config/reading-path-patterns.yaml for per-pattern canonical-scan descriptions.",
      "type": "object",
      "additionalProperties": false,
      "required": ["pattern"],
      "properties": {
        "pattern": {
          "type": "string",
          "enum": [
            "z_pattern",
            "f_pattern",
            "center_out",
            "top_down",
            "multi_column",
            "grid_quadrant",
            "sequence_numbered"
          ]
        },
        "confidence": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "evidence": {
          "type": "object",
          "additionalProperties": true,
          "description": "Per-pattern structured evidence (populated by classifier)."
        },
        "fallback": {
          "type": "boolean",
          "description": "True when the classifier fell back to z_pattern below the confidence threshold."
        }
      }
    }
  }
}
