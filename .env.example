# Copy to .env and fill in. Cursor / Claude Code load from environment or dotenv tools.

# --- Canvas (Instructure) REST API ---
# Docs: https://canvas.instructure.com/doc/api/
CANVAS_API_URL=https://your-institution.instructure.com/api/v1
CANVAS_ACCESS_TOKEN=

# Optional: default course for scripts (numeric ID from course URL or API)
CANVAS_DEFAULT_COURSE_ID=

# --- CourseArc ---
# Typically LTI 1.3 / SCORM for LMS embedding; ask CourseArc for any REST/export credentials.
COURSEARC_BASE_URL=
COURSEARC_API_KEY=

# --- Optional: other agent tools ---
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
