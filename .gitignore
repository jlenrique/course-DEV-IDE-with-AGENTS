# Local secrets — never commit
.env
.env.*
!.env.example

# Optional local-only drops (large media, exports)
secrets/
course-content/**/private/

# State runtime (SQLite + backups)
state/runtime/*.db
state/runtime/*.db-journal
state/runtime/backup/*.db

# Python
.venv/
__pycache__/
*.pyc
*.pyo
*.egg-info/
.pytest_cache/
.ruff_cache/
dist/
build/

# Generated media (large binary assets — keep locally, don't commit)
*.mp4
uv.lock

# OS / editor
.DS_Store
Thumbs.db
